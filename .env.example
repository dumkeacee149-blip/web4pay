# Docker Compose reads this file via env_file.
# Copy to .env and fill in values.

# Enable onchain mode for /v1/escrows (set to 1 or true to enable)
ONCHAIN_ENABLED=0

# Base mainnet RPC URL
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Deployed contracts (example)
ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
USDC_ADDRESS=0x0000000000000000000000000000000000000000

# Private key for signer wallet that submits onchain txs
SIGNER_PRIVATE_KEY=0xYOUR_64_HEX_PRIVATE_KEY

# Watcher settings (mock/daemon mode)
WATCHER_POLL_MS=3000
WATCHER_SETTLE_MS=1500
